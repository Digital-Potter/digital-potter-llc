		"eslint-plugin-prettier": "^5.4.0",
		"husky": "^9.1.7",
		"jest": "^30.0.4",
		"jest-environment-jsdom": "^30.0.4",
		"lint-staged": "^16.1.0",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"tailwindcss": "4.1.11",
		"ts-node": "10.9.2",
		"typescript": "5.9.3"
