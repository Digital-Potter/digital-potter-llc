		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-hook-form": "^7.75.0",
		"tailwind-merge": "3.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.1",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "4.1.11",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/dom": "10.4.0",
